# Copie para ".env" na RAIZ do projeto (mesma pasta que docker-compose.yml).
# O Docker Compose carrega automaticamente esse .env — não o do backend.

# Senha do utilizador root do MySQL (tem de coincidir com o que usa no import)
MYSQL_ROOT_PASSWORD=sua_senha_forte_aqui

# OBRIGATÓRIO: nome real da base (não use nomes de exemplo; alinhe com o teu .sql)
MYSQL_DATABASE=nome_real_da_sua_base

# CORS: só necessário se o frontend no browser chamar a API em :3000 (URL absoluta).
# Com o Nginx do contentor frontend, os pedidos vão a /api no mesmo host — não precisa de CORS para login.
# Se usar VITE_API_URL apontando para :3000, inclua aqui o origin do site, ex.:
# CORS_ORIGINS=http://localhost:5173,http://SEU_IP_OU_DOMINIO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Importar SQL na VPS (sem prompt de senha — não há espaço depois de -p):
#   docker exec -i meu-mysql mysql -u root -psua_senha_forte_aqui nome_do_seu_banco < /tmp/ficheiro.sql
# ou:
#   docker exec -i meu-mysql env MYSQL_PWD='sua_senha_forte_aqui' mysql -u root nome_do_seu_banco < /tmp/ficheiro.sql