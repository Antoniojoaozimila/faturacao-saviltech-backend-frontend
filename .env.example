# Copie para ".env" na RAIZ do projeto (mesma pasta que docker-compose.yml).
# O Docker Compose carrega automaticamente esse .env — não o do backend.

# Senha do utilizador root do MySQL (tem de coincidir com o que usa no import)
MYSQL_ROOT_PASSWORD=root123

# OBRIGATÓRIO: nome da base (igual ao USE / CREATE DATABASE do teu .sql)
# O projeto inclui sistema_cotacao.sql → use normalmente: sistema_cotacao
MYSQL_DATABASE=sistema_cotacao

# URL da API para o build do frontend (Vite). O Compose passa isto como build-arg.
# Mudou de IP/domínio? Altere aqui e faça: docker compose build --no-cache frontend
VITE_API_URL=http://147.93.89.17:3000

# CORS: origem do site no browser (porta 80). Obrigatório porque o React chama :3000 (origem diferente).
# Inclua também os hosts onde corres o Vite em desenvolvimento.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://147.93.89.17

# Importar SQL na VPS (sem prompt de senha — não há espaço depois de -p):
#   docker exec -i meu-mysql mysql -u root -psua_senha_forte_aqui nome_do_seu_banco < /tmp/ficheiro.sql
# ou:
#   docker exec -i meu-mysql env MYSQL_PWD='sua_senha_forte_aqui' mysql -u root nome_do_seu_banco < /tmp/ficheiro.sql